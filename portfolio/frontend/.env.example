# Portfolio Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================================================
# IMPRESSUM & DATENSCHUTZ
# These are baked into the static build - not secret, but kept out of git.
# Also set these in Cloudflare Pages: Settings > Environment Variables
# ============================================================================

NEXT_PUBLIC_IMPRESSUM_NAME=
NEXT_PUBLIC_IMPRESSUM_STRASSE=
NEXT_PUBLIC_IMPRESSUM_ORT=
NEXT_PUBLIC_IMPRESSUM_EMAIL=
NEXT_PUBLIC_IMPRESSUM_TELEFON=
# W-IdNr. nur eintragen sobald vom BZSt zugestellt (voraussichtlich ab Q4 2026)
# Format: DE + 9 Ziffern, z. B. DE123456789
NEXT_PUBLIC_IMPRESSUM_W_IDNR=

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# Base URL for backend API
# Development: http://localhost:4000
# Production: https://api.yourportfolio.com
NEXT_PUBLIC_API_URL=http://localhost:4000

# ============================================================================
# DEPRECATED: Folgende Variablen nicht mehr verwendet seit Aufgabe 07
# Frontend nutzt jetzt Backend REST API statt direkter DB-Zugriff
# Siehe: infos-und-aufgaben/DB_MIGRATION_NOTES.md
# ============================================================================

# # Database type: postgresql | mysql | sqlite
# DB_TYPE=postgresql

# # PostgreSQL/MySQL Connection
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=portfolio
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# # SQLite (alternative to PostgreSQL/MySQL)
# # DB_TYPE=sqlite
# # DB_PATH=./data/portfolio.db

# ============================================================================
# CONTACT FORM (Backend handled - no email service needed)
# ============================================================================

# Email service konfiguration entfernt - Backend speichert in MongoDB

# ============================================================================
# SECURITY
# ============================================================================

# Session secret for backend (if implementing authentication later)
SESSION_SECRET=generate_a_long_random_string_here

# ============================================================================
# DEVELOPMENT
# ============================================================================

# Enable debug logging
DEBUG=false

# Mock mode (use mock data instead of real DB for testing)
USE_MOCK_DATA=true
